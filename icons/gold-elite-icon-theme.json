    "package-lock.json": "_lock",
    "yarn.lock": "_lock",
    "pnpm-lock.yaml": "_lock",
    ".env": "_env",
    ".env.example": "_env",
    ".env.local": "_env",
    ".env.development": "_env",
    ".env.production": "_env",
    ".editorconfig": "_git",
    ".prettierrc": "_json",
    ".eslintrc": "_json",
    "tsconfig.json": "_json",
    "tsconfig": "_json"
