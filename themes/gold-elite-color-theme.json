  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "comment.block", "comment.line", "comment.block.documentation"],
      "settings": { "foreground": "#6E6A5E", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#C9B37E" }
    },
    {
      "name": "Numeric constants",
      "scope": "constant.numeric",
      "settings": { "foreground": "#E0B84A" }
    },
    {
      "name": "Language constants (bool/null)",
      "scope": "constant.language",
      "settings": { "foreground": "#BFA53A" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.word"],
      "settings": { "foreground": "#FFD700", "fontStyle": "bold" }
    },
    {
      "name": "Storage (let/const/function)",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#E0B84A" }
    },
    {
      "name": "Function declarations",
      "scope": ["entity.name.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#E7E3D6", "fontStyle": "bold" }
    },
    {
      "name": "Class names",
      "scope": ["entity.name.type.class", "entity.name.class"],
      "settings": { "foreground": "#F5D98A", "fontStyle": "bold" }
    },
    {
      "name": "Tag names (HTML/JSX)",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#BFA53A" }
    },
    {
      "name": "Attribute names",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#C9B37E" }
    },
    {
      "name": "Variables",
      "scope": "variable",
      "settings": { "foreground": "#E7E3D6" }
    },
    {
      "name": "Parameters",
      "scope": "variable.parameter",
      "settings": { "foreground": "#D8D2C2" }
    },
    {
      "name": "Support functions (built-ins)",
      "scope": "support.function",
      "settings": { "foreground": "#E0B84A" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "punctuation.definition", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#8A8578" }
    },
    {
      "name": "Invalid / illegal",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E06C4A", "fontStyle": "underline" }
    },
    {
      "name": "Markdown headings",
      "scope": "markup.heading",
      "settings": { "foreground": "#FFD700", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#F5D98A", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#C9B37E", "fontStyle": "italic" }
    }
  ],
  "semanticTokenColors": {
    "class": "#F5D98A",
    "interface": "#F5D98A",
    "enum": "#E0B84A",
    "typeParameter": "#D8D2C2",
    "type": "#BFA53A",
    "property": "#E7E3D6",
    "parameter": "#D8D2C2",
    "function": { "foreground": "#E7E3D6", "bold": true },
    "variable": "#E7E3D6",
    "namespace": "#BFA53A",
    "modifier": "#FFD700"
  }
}
